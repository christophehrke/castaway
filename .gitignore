# =============================================================================
# Laravel + Vue + Coolify workspace — .gitignore
# =============================================================================

# ── Environment & secrets ────────────────────────────────────────────────────
.env
.env.backup
.env.production
/auth.json
/storage/*.key

# ── PHP / Composer ───────────────────────────────────────────────────────────
/vendor
composer.phar
*.cache

# ── Node / Frontend build ────────────────────────────────────────────────────
node_modules/
/public/build
/public/hot
node-compile-cache/

# ── IDE & editor ─────────────────────────────────────────────────────────────
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
.phpactor.json
.phpunit.result.cache
*.swp
*.swo
*~

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Laravel storage ──────────────────────────────────────────────────────────
/public/storage
/storage/pail
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*

# ── Coolify / Coder workspace runtime ────────────────────────────────────────
code-server/
coder-script-data/
coder.*/
tmp.*

# ── Homestead (legacy) ──────────────────────────────────────────────────────
Homestead.json
Homestead.yaml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
