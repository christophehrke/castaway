{
    "manifest_version": 3,
    "name": "FlowCast Recorder",
    "version": "1.0.0",
    "description": "Record your screen and upload to FlowCast to generate n8n workflows.",
    "permissions": [
        "tabCapture",
        "storage",
        "offscreen"
    ],
    "host_permissions": [
        "https://*/*",
        "http://localhost/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
